# =============================================================================
# Kairos Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=kairos
POSTGRES_USER=kairos
POSTGRES_PASSWORD=changeme

# Async connection string (used by SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://kairos:changeme@localhost:5433/kairos

# Sync connection string (used by Alembic / migrations)
DATABASE_URL_SYNC=postgresql://kairos:changeme@localhost:5433/kairos

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434

# --- LiteLLM ---
LITELLM_CONFIG_PATH=litellm_config.yaml

# --- LLM Config (model routing & local/cloud toggle) ---
# See llm_config.yaml for full documentation of which agent uses which model.
# Set use_local_llms: false in llm_config.yaml to skip Ollama and go cloud-only.

# --- Langfuse (Observability) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- Discord Notifications ---
DISCORD_WEBHOOK_URL=

# --- Upload-Post API ---
UPLOAD_POST_API_KEY=

# --- Pipeline Defaults ---
DEFAULT_PIPELINE=physics
TARGET_DURATION_SEC=65
MAX_SIMULATION_ITERATIONS=5
SANDBOX_TIMEOUT_SEC=300
SANDBOX_MEMORY_LIMIT=4g
SANDBOX_CPU_LIMIT=2
